# .env.example

# Environment mode: development or production
MATRIX_MODE=development

# Database connection string
DATABASE_URL=postgresql://user:password@localhost:1234/matrix_db

# Secret key for external API
API_KEY=api_key

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# Resistance network endpoint
ZION_ENDPOINT=https://zion.resistance.net/api
